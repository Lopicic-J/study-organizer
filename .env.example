# Semetra — Lokale Umgebungsvariablen
# Kopiere diese Datei zu .env und trage deine Werte ein.
# WICHTIG: .env niemals ins Git committen!

# HMAC-Secret für Lizenzcode-Validierung
# Gleicher Wert wie in generate_license.py und Supabase-Secret SOAPP_HMAC_SECRET
SOAPP_HMAC_SECRET=dein_geheimer_hmac_schluessel

# Supabase Projekt-URL und Anon-Key (in Supabase Dashboard → Settings → API)
SOAPP_SB_URL=https://DEIN_REF.supabase.co
SOAPP_SB_KEY=DEIN_ANON_KEY
